DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="replace-with-a-long-random-secret"
FRONTEND_URL="https://saybee-ai.vercel.app"
CORS_ORIGIN="https://saybee-ai.vercel.app"

# Use one of these:
# Google Gemini native SDK key
GEMINI_API_KEY="your-google-gemini-api-key"
GEMINI_MODEL_NAME="gemini-1.5-flash"

# OpenRouter key for Gemini models
# OPENROUTER_API_KEY="your-openrouter-api-key"
# GEMINI_PROVIDER="openrouter"
# OPENROUTER_GEMINI_MODEL_NAME="google/gemini-2.0-flash-001"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="https://saybee-ai.onrender.com/api/auth/google/callback"
